+                                 or f"ib_direct_close_{direct_result.get('status')}",
+                        "order_id": direct_result.get("order_id"),
+                        "broker": "ib_direct",
+                        "ib_direct_status": direct_result.get("status"),
+                        "filled_qty": direct_result.get("filled_qty", 0),
