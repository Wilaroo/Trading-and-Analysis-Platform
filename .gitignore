# ============================================================
#  .gitignore for Trading-and-Analysis-Platform
# ============================================================

# Environment files
*.env
*.env.*
.env
.env.*
!.env.example

# Secrets (never commit)
*.secret
.ib_secret
.*_secret

# Python cache
**/__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# Virtual environments
venv/
.venv/
env/
ENV/

# Node / frontend
frontend/node_modules/
frontend/node_modules/.cache/
frontend/build/
frontend/.next/
frontend/dist/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs (keep training logs in the repo only if you want — leave commented)
*.log
!backend/training_subprocess.log
# Actually, training subprocess log is huge and rotates — ignore it too:
backend/training_subprocess.log

# Supervisor / runtime
*.pid
*.sock

# ============================================================
#  RUNTIME / PERSISTENT DATA — never commit these
# ============================================================

# ChromaDB vector store (SentCom embeddings, live-written)
backend/services/data/chromadb/
backend/services/data/chromadb/*.sqlite3
backend/services/data/chromadb/**/*.bin
backend/services/data/chromadb/**/*.pickle

# MongoDB exports / dumps
*.bson
*.gz
dump/

# Any SQLite DBs created at runtime
*.sqlite
*.sqlite3
*.db

# Trained model artifacts (stored in Mongo — don't duplicate to git)
backend/models/*.pt
backend/models/*.pth
backend/models/*.pkl
backend/models/*.joblib

# Temporary / test outputs
/tmp/
*.tmp
test_reports/
-e 
