<?xml version="1.0" encoding="UTF-16"?>
<!--
  TradeCommand Weekend Auto Task
  ==============================
  
  This Task Scheduler configuration will:
  1. Wake computer from sleep
  2. Run WeekendAuto.bat at scheduled times
  3. Run whether user is logged on or not
  
  HOW TO IMPORT:
  1. Open Task Scheduler (taskschd.msc)
  2. Click "Import Task..." in the right panel
  3. Select this XML file
  4. Update the following in the task:
     - Under "General" tab: Enter your Windows username/password
     - Under "Actions" tab: Update path to WeekendAuto.bat
     - Under "Triggers" tab: Adjust times as needed
  
  DEFAULT SCHEDULE:
  - Saturday 2:00 AM (full weekend batch)
  - Sunday 2:00 AM (full weekend batch)
  - Weekdays 9:00 PM (nightly refresh - optional, disabled by default)
-->
<Task version="1.4" xmlns="http://schemas.microsoft.com/windows/2004/02/mit/task">
  <RegistrationInfo>
    <Date>2026-03-15T00:00:00</Date>
    <Author>TradeCommand</Author>
    <Description>Automatically runs TradeCommand weekend batch processing - data collection, model training, and simulations.</Description>
    <URI>\TradeCommand Weekend Auto</URI>
  </RegistrationInfo>
  <Triggers>
    <!-- Saturday 2:00 AM -->
    <CalendarTrigger>
      <StartBoundary>2026-03-16T02:00:00</StartBoundary>
      <Enabled>true</Enabled>
      <ScheduleByWeek>
        <DaysOfWeek>
          <Saturday />
        </DaysOfWeek>
        <WeeksInterval>1</WeeksInterval>
      </ScheduleByWeek>
    </CalendarTrigger>
    <!-- Sunday 2:00 AM -->
    <CalendarTrigger>
      <StartBoundary>2026-03-17T02:00:00</StartBoundary>
      <Enabled>true</Enabled>
      <ScheduleByWeek>
        <DaysOfWeek>
          <Sunday />
        </DaysOfWeek>
        <WeeksInterval>1</WeeksInterval>
      </ScheduleByWeek>
    </CalendarTrigger>
    <!-- Weekday 9:00 PM (DISABLED by default - enable if you want nightly refreshes) -->
    <CalendarTrigger>
      <StartBoundary>2026-03-18T21:00:00</StartBoundary>
      <Enabled>false</Enabled>
      <ScheduleByWeek>
        <DaysOfWeek>
          <Monday />
          <Tuesday />
          <Wednesday />
          <Thursday />
          <Friday />
        </DaysOfWeek>
        <WeeksInterval>1</WeeksInterval>
      </ScheduleByWeek>
    </CalendarTrigger>
  </Triggers>
  <Principals>
    <Principal id="Author">
      <!-- UPDATE THIS: Replace with your Windows username -->
      <UserId>YOUR_USERNAME_HERE</UserId>
      <LogonType>Password</LogonType>
      <RunLevel>HighestAvailable</RunLevel>
    </Principal>
  </Principals>
  <Settings>
    <MultipleInstancesPolicy>IgnoreNew</MultipleInstancesPolicy>
    <DisallowStartIfOnBatteries>false</DisallowStartIfOnBatteries>
    <StopIfGoingOnBatteries>false</StopIfGoingOnBatteries>
    <AllowHardTerminate>true</AllowHardTerminate>
    <StartWhenAvailable>true</StartWhenAvailable>
    <RunOnlyIfNetworkAvailable>true</RunOnlyIfNetworkAvailable>
    <IdleSettings>
      <StopOnIdleEnd>false</StopOnIdleEnd>
      <RestartOnIdle>false</RestartOnIdle>
    </IdleSettings>
    <AllowStartOnDemand>true</AllowStartOnDemand>
    <Enabled>true</Enabled>
    <Hidden>false</Hidden>
    <RunOnlyIfIdle>false</RunOnlyIfIdle>
    <DisallowStartOnRemoteAppSession>false</DisallowStartOnRemoteAppSession>
    <UseUnifiedSchedulingEngine>true</UseUnifiedSchedulingEngine>
    <!-- WAKE COMPUTER FROM SLEEP -->
    <WakeToRun>true</WakeToRun>
    <!-- Allow to run for up to 12 hours -->
    <ExecutionTimeLimit>PT12H</ExecutionTimeLimit>
    <Priority>7</Priority>
  </Settings>
  <Actions Context="Author">
    <Exec>
      <!-- UPDATE THIS: Change path to where your WeekendAuto.bat is located -->
      <Command>C:\Users\YOUR_USERNAME\Documents\Trading\WeekendAuto.bat</Command>
      <WorkingDirectory>C:\Users\YOUR_USERNAME\Documents\Trading</WorkingDirectory>
    </Exec>
  </Actions>
</Task>
